# ─────────────────────────────────────────────────────────────────────────────
# Roger Winter portfolio — Caddy site block  (DEPLOYED on the VPS)
#
# Appended to the shared /etc/caddy/Caddyfile. The global options block (email,
# `acme_dns cloudflare {env.CF_API_TOKEN}`, trusted_proxies = Cloudflare ranges)
# is already present from the shared config and is left UNCHANGED — sheet-llm
# keeps using the global token.
#
# rogerwinter.dev gets its TLS cert from Let's Encrypt via the DNS-01 challenge
# using its OWN Cloudflare DNS-edit token, `CF_API_TOKEN_RW` (in
# /etc/caddy/caddy.env, mode 640 root:caddy), via the per-site `tls { dns … }`
# override below. This keeps sheet-llm's global CF_API_TOKEN untouched.
#
#   NOTE: adding a NEW env var to caddy.env requires a restart, not just a reload
#   (systemd reads EnvironmentFile at start): `sudo systemctl restart caddy`.
#
# Origin lock: `client_auth require_and_verify` against Cloudflare's
# Authenticated-Origin-Pull CA means only real Cloudflare connections complete
# the TLS handshake (verified: a direct-to-origin request is refused with
# "certificate required"). Requires AOP enabled + SSL/TLS Full(strict) on the
# zone, and the apex A/AAAA records proxied.
#
# www.rogerwinter.dev is handled by the redirect block at the bottom of this file
# (301 → apex). It carries its OWN `tls { dns … }` override so Caddy obtains a
# separate Let's Encrypt cert for the www name via DNS-01; without that block the
# origin had no cert for www and Cloudflare (Full strict) returned 525 on the
# www host. The www apex record must be proxied in Cloudflare (it is).
#
# DEFERRED — rogerwinter.biz: needs its own proxied DNS record first, plus
# onboarding that zone + a token that covers it. When ready, add a redirect block
# that ALSO carries a per-site dns token covering the .biz zone.
#
# After editing: `sudo caddy validate --config /etc/caddy/Caddyfile` (note: a
# standalone validate run shows an empty-token warning because caddy.env isn't
# loaded in your shell — harmless; the service has the tokens) then
# `sudo systemctl restart caddy`.
# ─────────────────────────────────────────────────────────────────────────────

rogerwinter.dev {
	encode zstd gzip

	tls {
		dns cloudflare {env.CF_API_TOKEN_RW}
		client_auth {
			mode require_and_verify
			trust_pool file {
				pem_file /etc/caddy/cf-origin-pull-ca.pem
			}
		}
	}

	reverse_proxy 127.0.0.1:3001
}

# Canonical-host redirect: www → apex. Carries its own per-site DNS token so Caddy
# can solve the DNS-01 challenge and mint a cert for the www name (the apex block's
# cert does not cover it). Without a valid origin cert here, Cloudflare (SSL/TLS
# Full strict) fails the origin TLS handshake and serves a 525 on www. The origin
# lock (client_auth) mirrors the apex block so www is also reachable only via real
# Cloudflare connections — same AOP trust pool, same posture.
www.rogerwinter.dev {
	tls {
		dns cloudflare {env.CF_API_TOKEN_RW}
		client_auth {
			mode require_and_verify
			trust_pool file {
				pem_file /etc/caddy/cf-origin-pull-ca.pem
			}
		}
	}

	redir https://rogerwinter.dev{uri} permanent
}

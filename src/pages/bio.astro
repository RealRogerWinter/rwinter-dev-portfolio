---
// Bio — editorial redesign. Reuses B's framed-photo hero + atmosphere, drops the
// stat strip / timeline / ring graphic, and adds one decorative animated "signal"
// divider to break up the narrative. Styles in bio.css (bvb- classes). No shared
// file touched; pure CSS/SVG motion, no framework JS.
import Page from '../layouts/Page.astro';
import '../styles/bio.css';

const skills = ['TypeScript', 'Python', 'React', 'Node', 'LLMs', 'WebRTC'];
const glance = [
  { k: 'role', v: 'Developer Advocate' },
  { k: 'builds', v: 'web apps, LLM tools, AI agents, realtime apps' },
  { k: 'writes', v: 'developer tutorials and in-depth technical guides' },
  { k: 'developed content for', v: 'CircleCI, Microsoft, Meta, Red Hat, Docker, Snyk, and more' },
  { k: 'open to', v: 'full-time roles and select collaboration' },
];
---
<Page
  title="Bio, Roger Winter"
  description="Roger Winter, Developer Advocate. I build AI and web software, then write the technical content that explains it."
  canonical="https://rogerwinter.dev/bio.html"
  active="bio"
>
  {/* ============================== HERO ============================== */}
  <header class="bvb-hero">
    <div class="bvb-atmo" aria-hidden="true">
      <span class="bvb-blob b1"></span>
      <span class="bvb-blob b2"></span>
      <span class="bvb-blob b3"></span>
    </div>

    <div class="bvb-herogrid">
      <div class="bvb-introcol">
        <p class="bvb-kicker reveal">About</p>
        <h1 class="bvb-h1 reveal d1">Hi, I'm<br /><span class="nm">Roger Winter.</span></h1>
        <p class="bvb-lead reveal d2">
          I build AI and web software, then write the technical content that
          explains how it holds up. <span class="hl">The build is the experiment;
          the writeup is the result.</span>
        </p>
        <div class="bvb-meta reveal d3">
          <span class="bvb-avail"><i></i> Open to full-time roles and select collaboration</span>
        </div>
      </div>

      <figure class="bvb-photo reveal d2">
        <div class="bvb-photo-glow" aria-hidden="true"></div>
        <div class="bvb-photo-frame">
          <picture>
            <source media="(min-width: 700px)" srcset="/portfolio/assets/roger-winter-full.jpg" />
            <img
              src="/portfolio/assets/roger-winter-hero.jpg"
              width="1400"
              height="1050"
              alt="Roger Winter"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
          <span class="bvb-photo-rim" aria-hidden="true"></span>
        </div>
        <figcaption class="bvb-photo-tag">
          <span class="dot" aria-hidden="true"></span>Roger Winter · Developer Advocate
        </figcaption>
      </figure>
    </div>
  </header>

  {/* =========================== BODY GRID =========================== */}
  <div class="bvb-body">
    <div class="bvb-main">
      <section class="bvb-block">
        <p class="bvb-kicker">The story</p>
        <h2 class="bvb-h2">Build the thing, then explain it.</h2>
        <div class="bvb-prose">
          <p>I taught myself to program at 11 and took my first paid web work at 14. For years that meant building sites on the LAMP stack and specializing in WordPress as a freelance developer, learning the craft by shipping real things for real clients.</p>
          <p>Content found me through the side door. I got into affiliate marketing and built Hydration Anywhere, a product-review site that ranked #1 on Google for "best water bottles." Doing the SEO writing while building the site is where the pattern that defines my work started: build the thing, then explain it in writing people trust.</p>
          <p>That pattern turned into a career in technical content. At ContentLab I designed and ran content strategy for some of the biggest names in software, and over those years I developed technical content for <strong>CircleCI, Microsoft, Meta, Red Hat, Docker, Snyk, and more</strong>. The work was to take hard engineering topics and turn them into tutorials and in-depth guides developers use, which meant learning each product well enough to be honest about it.</p>

          <div class="bvb-sig" aria-hidden="true">
            <span class="sig-glow"></span>
            <svg viewBox="0 0 620 74" preserveAspectRatio="xMidYMid meet">
              <path class="sig-base" d="M0,37 Q77,8 155,37 T310,37 T465,37 T620,37" />
              <path class="sig-path" d="M0,37 Q77,8 155,37 T310,37 T465,37 T620,37" />
              <circle class="sig-node" cx="155" cy="37" r="3" />
              <circle class="sig-node" cx="310" cy="37" r="3.6" />
              <circle class="sig-node" cx="465" cy="37" r="3" />
            </svg>
          </div>

          <p>AI is where the two halves of my work fused. I build AI into every part of the content pipeline, including a Claude Code skill that runs every command and code sample in a Docker container before it updates a post and opens a pull request.</p>
          <p>I also ship AI projects designed to make the model prove its work: a neural net that learns to price products live on Twitch, an LLM-orchestrated notation editor, a browser game written end to end by Claude Code agents, a multilingual SEO tool, and an Algebra 1 course where SymPy re-checks every answer in CI.</p>
          <p>I'm a <strong>developer advocate</strong>: an engineer and writer who builds the thing and explains it, and who cares about AI you can verify.</p>
        </div>
      </section>
    </div>

    <aside class="bvb-rail">
      <div class="bvb-railsticky">
        <div class="bvb-panel">
          <div class="bvb-panel-bar"><span class="ttl">At a glance</span></div>
          <div class="bvb-panel-body">
            <dl class="bvb-kv">
              {glance.map((g) => (
                <>
                  <dt>{g.k}</dt>
                  <dd>{g.v}</dd>
                </>
              ))}
            </dl>
          </div>
        </div>

        <div class="bvb-panel">
          <div class="bvb-panel-bar"><span class="ttl">Works with</span></div>
          <div class="bvb-panel-body">
            <div class="bvb-tags">
              {skills.map((s) => <span class="bvb-tag">{s}</span>)}
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  {/* =========================== PAST WORK =========================== */}
  <section class="bvb-pastwork">
    <p class="bvb-kicker">Past work</p>
    <p class="bvb-pastline">
      By-lined technical writing and video for developer-tool companies: tutorials, explainers, and in-depth guides.
      <a class="bvb-inline-link" href="/past-work.html">See the work →</a>
    </p>
  </section>

  {/* ============================== CTA ============================== */}
  <section class="bvb-cta">
    <div class="bvb-cta-atmo" aria-hidden="true"></div>
    <div class="bvb-cta-inner">
      <p class="bvb-kicker">Let's talk</p>
      <a class="bvb-cta-link" href="/contact.html">Building in this space, or hiring for it? Let's talk. →</a>
    </div>
  </section>
</Page>

---
// Shared page shell for migrated Astro pages. Reproduces the <head> the old
// pages emit, links the extracted shell stylesheet, and renders the themed
// .tm.rw root + Nav + slot + Footer exactly as window.BioPage et al. did.
import '../styles/shell.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title, description, canonical, active, rootClass = '', ogType = 'website', ogImage } = Astro.props;
const OG_IMG = 'https://rogerwinter.dev/portfolio/assets/og-cover.png';
const OG_ALT = 'Roger Winter, Developer Advocate';
// Project pages unfurl as articles with a per-project image. Only the generic
// site cover has known 1200x630 dimensions, so the image:type/width/height/alt
// meta is emitted for that default alone (the old project pages omitted it
// rather than assert wrong dimensions for a differently-sized hero shot).
const ogImg = ogImage || OG_IMG;
const ogDefaultImg = !ogImage;

// Pre-paint theme bootstrap: runs synchronously INSIDE #rw-root (right after its
// opening tag, before the content paints), so a returning visitor's saved theme
// is applied with no flash. Defaults mirror TW_DEFAULTS + rootPropsRW in
// site/portfolio/shell.jsx. Allowed by the current script-src 'unsafe-inline';
// at cutover (Babel removed) it becomes a CSP hash.
const themeBoot =
  "(function(){try{var d=document.getElementById('rw-root');" +
  "var t=Object.assign({theme:'dark',background:'weave',accent:'#5b8cff',display:'Syne',lift:true,vizAnim:true}," +
  "JSON.parse(localStorage.getItem('rw_tweaks_v1')||'{}'));" +
  "var F={'Syne':\"'Syne', sans-serif\",'Space Grotesk':\"'Space Grotesk', sans-serif\",'Bricolage Grotesque':\"'Bricolage Grotesque', sans-serif\"};" +
  "d.setAttribute('data-theme',t.theme);d.setAttribute('data-bg',t.background||'grid');" +
  "d.style.setProperty('--acc',t.accent);d.style.setProperty('--display',F[t.display]||F['Syne']);" +
  "d.classList.toggle('motion-lift',!!t.lift);d.setAttribute('data-anim',t.vizAnim!==false?'on':'off');}catch(e){}})();";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/vendor/fonts/fonts.css" />
    <style is:inline>
      html, body { margin: 0; padding: 0; background: #0b0d0c; }
      * { box-sizing: border-box; }
      ::selection { background: color-mix(in srgb, var(--acc, #57f08d) 30%, transparent); }
    </style>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0b0d0c" />
    <meta name="author" content="Roger Winter" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Roger Winter" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    {ogDefaultImg && (
      <>
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={OG_ALT} />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />
    {ogDefaultImg && <meta name="twitter:image:alt" content={OG_ALT} />}
  </head>
  <body>
    <div id="rw-root" class:list={['tm', 'rw', 'motion-lift', rootClass]} data-theme="dark" data-bg="weave" data-anim="on" style="--acc:#5b8cff;--display:'Syne', sans-serif">
      <script is:inline set:html={themeBoot}></script>
      <div class="tm-wrap">
        <Nav active={active} />
        <slot />
        <Footer />
      </div>
    </div>
  </body>
</html>

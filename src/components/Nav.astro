---
// Shared site nav — ports window.Nav from site/portfolio/shell.jsx. The `active`
// prop is a page key ("home" | "bio" | "contact" | "project-*"); only keys in the
// item list highlight, so e.g. "contact" is intentionally a no-op (Contact is the
// CTA button, not a nav link).
import { social } from '../data/site.js';
const { active } = Astro.props;
const HOME = '/';
const items = [
  { k: 'home', label: 'Projects', href: HOME },
  { k: 'bio', label: 'Bio', href: 'bio.html' },
];
---
<nav class="tm-nav">
  <a class="tm-brand" href={HOME}>
    <span class="tm-mono">RW</span><span class="tm-wordmark">Roger Winter</span>
  </a>
  <div class="tm-navright">
    <div class="tm-navlinks">
      {items.map((it) => <a href={it.href} class={active === it.k ? 'active' : undefined}>{it.label}</a>)}
      <a href={social.github.href} target="_blank" rel="noopener">GitHub</a>
    </div>
    <a class="tm-cta" href="contact.html">Contact</a>
  </div>
</nav>
